% -------- RULES --------

% Edible items
edible(X) :-
    fruit(X);
    vegetable(X).

% Sweet fruits
sweet_fruit(X) :-
    fruit(X),
    taste(X, sweet).

% Sour fruits
sour_fruit(X) :-
    fruit(X),
    taste(X, sour).

% Leafy vegetables
leafy_vegetable(X) :-
    vegetable(X),
    (X = spinach; X = cabbage).

% Root vegetables
root_vegetable(X) :-
    vegetable(X),
    (X = carrot; X = potato; X = onion).

% Green vegetables
green_vegetable(X) :-
    vegetable(X),
    color(X, green).

% General classification
type(X, fruit) :-
    fruit(X).

type(X, vegetable) :-
    vegetable(X).



