% -------- RULES --------

% Check if a person satisfies all requirements of a job
qualified(Person, Job) :-
    job(Job, _),  % ensure job exists
    forall(job(Job, Skill), has_skill(Person, Skill)).

% Suggest suitable job
suggest_job(Person, Job) :-
    qualified(Person, Job).

% Partial match (at least one skill matches)
partial_match(Person, Job) :-
    job(Job, Skill),
    has_skill(Person, Skill).

% Count matching skills (optional advanced rule)
match_count(Person, Job, Count) :-
    findall(Skill, (job(Job, Skill), has_skill(Person, Skill)), Skills),
    length(Skills, Count).


Commands : 
